        },
        {
            "label": "4. Build & Run: Linux32 Native (Custom main)",
            "type": "shell",
            "command": "nasm -f elf32 \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}.o\" && ld -m elf_i386 -e main \"${fileDirname}/${fileBasenameNoExtension}.o\" -o \"${fileDirname}/${fileBasenameNoExtension}\" && \"${fileDirname}/${fileBasenameNoExtension}\"",
            "group": "build",
            "problemMatcher": {
                "owner": "nasm",
                "fileLocation": ["absolute"],
                "pattern": {
                    "regexp": "^(.*):(\\d+):\\s+(error|warning|fatal):\\s+(.*)$",
