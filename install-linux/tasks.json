        },
        {
            "label": "5. Build & Run: Win32 Irvine (Standard)",
            "type": "shell",
            "command": "uasm -q -coff -I./irvine \"${file}\" -Fo\"${fileDirname}/${fileBasenameNoExtension}.o\" && i686-w64-mingw32-gcc \"${fileDirname}/${fileBasenameNoExtension}.o\" ./irvine/Irvine32.lib -o \"${fileDirname}/${fileBasenameNoExtension}.exe\" -nostdlib -lkernel32 -luser32 -w -Wl,--subsystem,console && WINEDEBUG=-all wine \"${fileDirname}/${fileBasenameNoExtension}.exe\"",
            "group": "build",
            "problemMatcher": {
                "owner": "uasm",
                "fileLocation": ["absolute"],
                "pattern": {
                    "regexp": "^(.*)\\((\\d+)\\)\\s+:\\s+(error|warning|fatal)\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "message": 4
                }
            },
            "presentation": { "reveal": "always", "panel": "shared", "clear": true }
        },
