{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build & Run Windows 32-bit",
            "type": "shell",
            "command": "nasm -f win32 ${file} -o ${fileBasenameNoExtension}.obj && i686-w64-mingw32-gcc ${fileBasenameNoExtension}.obj -o ${fileBasenameNoExtension}.exe -nostartfiles -lkernel32 -luser32 && wine ${fileBasenameNoExtension}.exe",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build & Run Windows 64-bit",
            "type": "shell",
            "command": "nasm -f win64 ${file} -o ${fileBasenameNoExtension}.obj && x86_64-w64-mingw32-gcc ${fileBasenameNoExtension}.obj -o ${fileBasenameNoExtension}.exe -nostartfiles -lkernel32 -luser32 && wine ${fileBasenameNoExtension}.exe",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Build & Run Linux 64-bit",
            "type": "shell",
            "command": "nasm -f elf64 ${file} -o ${fileBasenameNoExtension}.o && ld ${fileBasenameNoExtension}.o -o ${fileBasenameNoExtension} && ./${fileBasenameNoExtension}",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}